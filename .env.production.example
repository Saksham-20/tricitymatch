# =============================================================================
# TricityShadi Production Environment Configuration
# =============================================================================
# IMPORTANT: Never commit this file with real values to version control!
# Use environment variables or a secrets manager in production.
# =============================================================================

NODE_ENV=production

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
PORT=5000
FRONTEND_URL=https://tricityshadi.com

# -----------------------------------------------------------------------------
# DATABASE (Use strong credentials!)
# -----------------------------------------------------------------------------
DB_HOST=your-db-host.cloud-provider.com
DB_PORT=5432
DB_USER=tricitymatch_prod
DB_PASSWORD=<STRONG_RANDOM_PASSWORD>
DB_NAME=tricitymatch_production
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_MIN=5

# -----------------------------------------------------------------------------
# REDIS (Use cloud Redis with TLS)
# -----------------------------------------------------------------------------
REDIS_URL=rediss://user:password@your-redis.cloud:6379
# Or individual settings:
# REDIS_HOST=your-redis.cloud.com
# REDIS_PORT=6379
# REDIS_PASSWORD=<REDIS_PASSWORD>
# REDIS_TLS=true

# -----------------------------------------------------------------------------
# SECURITY (Generate unique, strong secrets!)
# -----------------------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64_CHAR_RANDOM_HEX_STRING>
COOKIE_SECRET=<ANOTHER_64_CHAR_RANDOM_STRING>
CSRF_SECRET=<CSRF_RANDOM_STRING>

JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
RESET_TOKEN_EXPIRY=1h
BCRYPT_ROUNDS=12

# Stricter rate limits for production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=60
AUTH_RATE_LIMIT_MAX=3
AUTH_RATE_LIMIT_WINDOW_MS=900000
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=60

# -----------------------------------------------------------------------------
# PAYMENT (Production Razorpay Keys)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<LIVE_SECRET>
RAZORPAY_WEBHOOK_SECRET=<WEBHOOK_SECRET>

# -----------------------------------------------------------------------------
# EMAIL (Production SMTP)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_SECURE=true
EMAIL_USER=noreply@tricityshadi.com
EMAIL_PASSWORD=<EMAIL_PASSWORD>
EMAIL_FROM=TricityShadi <noreply@tricityshadi.com>

# -----------------------------------------------------------------------------
# CLOUDINARY
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=tricitymatch-prod
CLOUDINARY_API_KEY=<API_KEY>
CLOUDINARY_API_SECRET=<API_SECRET>
CLOUDINARY_FOLDER=tricitymatch-production

# -----------------------------------------------------------------------------
# AGORA (Video/Voice Calls — Sessions 8+9)
# Register at agora.io → Project Management → App Certificate
# -----------------------------------------------------------------------------
AGORA_APP_ID=<YOUR_AGORA_APP_ID>
AGORA_APP_CERTIFICATE=<YOUR_AGORA_APP_CERTIFICATE>
AGORA_TOKEN_EXPIRY=3600

# -----------------------------------------------------------------------------
# SMS / OTP (Session 13 — Real OTP)
# Use Fast2SMS or MSG91
# Fast2SMS: https://fast2sms.com → API → Dev API
# MSG91: https://msg91.com → API → Auth Key
# Leave SMS_PROVIDER=dev for console-logged OTPs (dev only)
# -----------------------------------------------------------------------------
SMS_PROVIDER=fast2sms
SMS_API_KEY=<YOUR_FAST2SMS_OR_MSG91_API_KEY>

# -----------------------------------------------------------------------------
# FCM PUSH NOTIFICATIONS (Sessions 8+13)
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
# Store the file in a secure location and reference it here
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=<YOUR_FIREBASE_PROJECT_ID>
FCM_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json

# -----------------------------------------------------------------------------
# BACKGROUND CHECK (Session 19 — APP-060 real integration)
# Set BG_CHECK_PROVIDER to 'authbridge' or 'signzy'. Leave blank for dev stub.
# AuthBridge: https://authbridge.com — enterprise KYC/BGV API
#   BG_CHECK_API_KEY       = Bearer token from AuthBridge dashboard
#   BG_CHECK_API_SECRET    = client secret
#   AUTHBRIDGE_BASE_URL    = override if on staging (default: https://api.authbridge.com/v1)
# Signzy: https://signzy.com — India-focused, court + aadhaar + marital
#   BG_CHECK_API_KEY       = Signzy API key (Authorization header)
#   SIGNZY_PATRON_ID       = your Patron ID from Signzy dashboard
#   SIGNZY_BASE_URL        = override for staging
# Webhook: provider will POST to /api/v1/verification/bg-check/webhook
#   BG_CHECK_WEBHOOK_SECRET = shared secret for HMAC-SHA256 signature verification
# -----------------------------------------------------------------------------
BG_CHECK_PROVIDER=
BG_CHECK_API_KEY=
BG_CHECK_API_SECRET=
BG_CHECK_WEBHOOK_SECRET=
AUTHBRIDGE_BASE_URL=
SIGNZY_BASE_URL=
SIGNZY_PATRON_ID=

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
MONITORING_ENABLED=true
ALERT_EMAILS=ops@tricityshadi.com,alerts@tricityshadi.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# -----------------------------------------------------------------------------
# ADMIN
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@tricityshadi.com

# -----------------------------------------------------------------------------
# CORS (Restrict to your domain only)
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://tricityshadi.com

# Disable Swagger in production for security
ENABLE_SWAGGER=false

# -----------------------------------------------------------------------------
# DOCKER COMPOSE
# -----------------------------------------------------------------------------
BACKEND_PORT=5000
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
GRAFANA_PASSWORD=<SECURE_GRAFANA_PASSWORD>
VITE_API_URL=https://tricityshadi.com/api
