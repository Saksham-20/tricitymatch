{
  "name": "tricitymatch-backend",
  "version": "1.0.0",
  "description": "Backend API for TricityShadi matrimonial website",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --coverage --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPattern=tests/unit",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=tests/integration",
    "test:ci": "cross-env NODE_ENV=test jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint . --ext .js --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .js --ignore-path .gitignore --fix",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "migrate:test": "cross-env NODE_ENV=test sequelize-cli db:migrate",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo:all",
    "db:reset": "npm run db:drop && npm run db:create && npm run migrate && npm run seed",
    "db:reset:test": "cross-env NODE_ENV=test npm run db:drop && cross-env NODE_ENV=test npm run db:create && cross-env NODE_ENV=test npm run migrate",
    "db:create": "sequelize-cli db:create",
    "db:drop": "sequelize-cli db:drop"
  },
  "keywords": [
    "matrimonial",
    "tricity",
    "matchmaking"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "agora-access-token": "^2.0.4",
    "bcryptjs": "^3",
    "bull": "^4.12.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "razorpay": "^2.9.2",
    "resend": "^6.16.0",
    "sequelize": "^6.35.0",
    "sequelize-cli": "^6.6.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "umzug": "^2.3.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
