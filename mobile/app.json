{
  "name": "TricityShadi",
  "displayName": "TricityShadi",
  "expo": {
    "name": "TricityShadi",
    "slug": "tricityshadi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E11D48"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tricityshadi.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used for profile photos and selfie verification.",
        "NSMicrophoneUsageDescription": "Microphone is used for voice and video calls.",
        "NSPhotoLibraryUsageDescription": "Photo library access is used for uploading profile photos.",
        "NSFaceIDUsageDescription": "Face ID is used for quick and secure login.",
        "NSLocalAuthenticationUsageDescription": "Biometric authentication is used for quick and secure login."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E11D48"
      },
      "package": "com.tricityshadi.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "tricityshadi-app"
      }
    }
  }
}
