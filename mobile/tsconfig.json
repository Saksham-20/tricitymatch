{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "module": "ESNext",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "App.tsx",
    "index.js",
    "../shared/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "../node_modules",
    "../frontend",
    "../backend",
    "../e2e"
  ]
}
