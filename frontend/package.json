    "typescript": "^5.3.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze && npx source-map-explorer dist/assets/js/*.js --html dist/bundle-report.html",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=./junit.xml",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "size": "npx vite-bundle-visualizer"
  }
